Options -MultiViews
RewriteEngine On
RewriteBase /

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} /index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect /contact.html to /contact
RewriteCond %{THE_REQUEST} /contact\.html[\s?] [NC]
RewriteRule ^contact\.html$ /contact [R=301,L]

# Serve contact.html for /contact
RewriteRule ^contact/?$ contact.html [L]

# Serve index.html for all section paths
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(about|services|niches|why-us)/?$ index.html [L]
